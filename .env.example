# Optional. Etherscan V2 multi-chain API key for higher rate limits.
# The app works without this key using the free tier + eth_getLogs fallback.
# Used by the Vite SPA (VITE_*) and the Node MCP server.
VITE_ETHERSCAN_API_KEY=

# --- Node server / remote MCP (npm start) ---
# PORT=3000

# Bearer auth for Cursor / custom clients (≥16 chars). MCP disabled (503) if unset.
MCP_API_KEY=

# OAuth for Claude.ai / Cursor connectors (optional; requires MCP_API_KEY).
# MCP_PUBLIC_URL = public https ORIGIN only (no /mcp path).
# Good:  https://settlementos-explorer-ihgo.onrender.com
# Bad:   https://….onrender.com/mcp
# On Render, RENDER_EXTERNAL_URL is used if MCP_PUBLIC_URL is unset.
# Prefer static MCP_OAUTH_CLIENT_ID / SECRET in Claude Advanced settings.
# Dynamic Client Registration is OFF by default (set true only if needed).
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=
# MCP_PUBLIC_URL=
# MCP_OAUTH_ALLOW_DCR=false
